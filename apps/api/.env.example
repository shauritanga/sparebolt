# Database
DATABASE_URL="postgresql://sparebolt:sparebolt@localhost:5432/sparebolt?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
CORS_ORIGIN="http://localhost:5173"
PLATFORM_FEE_PERCENT=5
NODE_ENV=development

# ClickPesa payments
CLICKPESA_API_URL="https://api.clickpesa.com/v1"
CLICKPESA_API_KEY=""
CLICKPESA_SECRET=""
CLICKPESA_WEBHOOK_SECRET=""

# SMS / OTP (Africa's Talking or similar)
SMS_PROVIDER="mock"
SMS_API_KEY=""
SMS_SENDER_ID="SpareBolt"

# Public base URL for absolute upload links (optional; relative /uploads works via Vite proxy)
PUBLIC_BASE_URL="http://localhost:3001"

# Storage (optional S3/MinIO later; local disk is default)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="sparebolt"
S3_SECRET_KEY="sparebolt_secret"
S3_BUCKET="sparebolt"
S3_PUBLIC_URL="http://localhost:9000/sparebolt"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

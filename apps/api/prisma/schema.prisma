// SpareBolt — Vehicle Spare Parts Marketplace
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  SELLER
  DRIVER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PartCondition {
  NEW
  USED
  REFURBISHED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID_ESCROW
  AWAITING_DRIVER
  DRIVER_ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED_TO_SELLER
  REFUNDED_TO_CUSTOMER
  PARTIAL_REFUND
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CUSTOMER
  RESOLVED_SELLER
  CLOSED
}

enum NotificationType {
  ORDER
  DELIVERY
  PAYMENT
  SYSTEM
  REVIEW
  APPROVAL
}

enum PromoStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

enum PromoPackage {
  STARTER   // 3 days
  STANDARD  // 7 days
  PREMIUM   // 14 days — priority slot
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  firstName     String
  lastName      String
  avatarUrl     String?
  role          Role      @default(CUSTOMER)
  locale        String    @default("en") // en | sw
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  googleId      String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sellerProfile  SellerProfile?
  driverProfile  DriverProfile?
  addresses      Address[]
  orders         Order[]         @relation("CustomerOrders")
  reviewsGiven   Review[]        @relation("ReviewsGiven")
  notifications  Notification[]
  otpCodes       OtpCode[]
  pushTokens     PushToken[]

  @@index([role])
  @@index([phone])
  @@map("users")
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?
  phone     String
  code      String
  purpose   String   // login | verify | reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@map("otp_codes")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String   // web | android | ios
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("push_tokens")
}

// ─── Profiles ────────────────────────────────────────────────────────────────

model SellerProfile {
  id             String         @id @default(cuid())
  userId         String         @unique

  // ── Business ──
  businessName   String
  businessType   String?        // individual | partnership | company
  description    String?
  registrationNumber String?    // BRELA / company reg
  tinNumber      String?
  yearsTrading   Int?

  // ── Identity of responsible person ──
  legalFullName      String?
  nationalId         String?
  nationalIdFrontUrl String?
  nationalIdBackUrl  String?
  selfieUrl          String?
  dateOfBirth        DateTime?
  secondaryPhone     String?

  // ── Location ──
  addressStreet  String?
  addressArea    String?
  addressWard    String?
  city           String
  region         String?
  addressLandmark String?
  latitude       Float?
  longitude      Float?
  shopExteriorUrl String?
  shopInteriorUrl String?

  // ── Payout (must match ID / business name) ──
  payoutMethod      String?     // mobile_money | bank
  payoutPhone       String?
  payoutAccountName String?
  bankName          String?
  bankAccountNumber String?

  // ── Legacy / optional trade licence ──
  licenseNumber  String?

  // ── Consents ──
  termsAcceptedAt   DateTime?
  dataConsentAt     DateTime?
  accurateListingAt DateTime?

  // ── Ops ──
  status         ApprovalStatus @default(PENDING)
  rejectionReason String?
  ratingAvg      Float          @default(0)
  ratingCount    Int            @default(0)
  totalSales     Int            @default(0)
  platformFeePct Float          @default(5.0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]
  reviews  Review[]  @relation("SellerReviews")
  promos   PromoAd[]

  @@index([status, city])
  @@index([nationalId])
  @@map("seller_profiles")
}

model DriverProfile {
  id              String         @id @default(cuid())
  userId          String         @unique

  // ── Identity (theft / fraud trail) ──
  legalFullName     String?
  nationalId        String?
  nationalIdFrontUrl String?
  nationalIdBackUrl  String?
  selfieUrl         String?
  dateOfBirth       DateTime?
  secondaryPhone    String?

  // ── Residential address ──
  addressStreet   String?
  addressArea     String?
  addressWard     String?
  city            String
  addressLandmark String?
  homeLatitude    Float?
  homeLongitude   Float?

  // ── Vehicle ──
  vehicleType     String         // motorcycle | car | van
  vehiclePlate    String
  vehicleMake     String?
  vehicleModel    String?
  vehicleColor    String?
  vehicleYear     Int?
  vehiclePhotoSideUrl       String?
  vehiclePhotoRearUrl       String?
  vehiclePhotoWithDriverUrl String?

  // ── Licence & insurance ──
  licenseNumber   String
  licenseClass    String?
  licensePhotoUrl String?
  licenseVerified Boolean        @default(false)
  insuranceDocUrl String?
  insuranceExpiresAt DateTime?

  // ── Payout (must match ID name) ──
  payoutMethod      String?      // mobile_money | bank
  payoutPhone       String?
  payoutAccountName String?
  bankName          String?
  bankAccountNumber String?

  // ── Emergency + guarantor ──
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  guarantorName     String?
  guarantorPhone    String?
  guarantorIdNumber String?
  guarantorAddress  String?

  // ── Consents ──
  termsAcceptedAt   DateTime?
  dataConsentAt     DateTime?
  trackingConsentAt DateTime?

  // ── Ops ──
  latitude        Float?
  longitude       Float?
  isOnline        Boolean        @default(false)
  status          ApprovalStatus @default(PENDING)
  rejectionReason String?
  ratingAvg       Float          @default(0)
  ratingCount     Int            @default(0)
  totalDeliveries Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
  reviews    Review[]    @relation("DriverReviews")

  @@index([status, isOnline, city])
  @@index([nationalId])
  @@index([vehiclePlate])
  @@map("driver_profiles")
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String   // Home, Work, etc.
  street     String
  area       String?
  city       String
  region     String?
  postalCode String?
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  nameEn    String
  nameSw    String
  slug      String     @unique
  icon      String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  listings  Listing[]
  sortOrder Int        @default(0)

  @@map("categories")
}

model VehicleMake {
  id     String         @id @default(cuid())
  name   String         @unique
  models VehicleModel[]

  @@map("vehicle_makes")
}

model VehicleModel {
  id     String      @id @default(cuid())
  makeId String
  name   String
  make   VehicleMake @relation(fields: [makeId], references: [id], onDelete: Cascade)

  @@unique([makeId, name])
  @@map("vehicle_models")
}

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  categoryId  String
  title       String
  description String
  partNumber  String?
  condition   PartCondition @default(NEW)
  price       Decimal       @db.Decimal(12, 2)
  /// Previous / list price for strikethrough UI when higher than price
  compareAtPrice Decimal?   @db.Decimal(12, 2)
  currency    String        @default("TZS")
  quantity    Int           @default(1)
  isActive    Boolean       @default(true)
  // Specs / catalog details
  manufacturer String?      // e.g. Toyota OEM, Bosch
  brand        String?      // marketing brand
  partType     String?      // Genuine | Aftermarket | OEM
  engine       String?      // e.g. 1KD-FTV, 4.5
  warrantyMonths Int?
  // Vehicle compatibility
  make        String?
  model       String?
  yearFrom    Int?
  yearTo      Int?
  // Location
  city        String
  latitude    Float?
  longitude   Float?
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller     SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id])
  images     ListingImage[]
  orderItems OrderItem[]
  promos     PromoAd[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([make, model])
  @@index([city, isActive])
  @@index([price])
  @@map("listings")
}

// ─── Home carousel promotions (seller-subscribed) ────────────────────────────

model PromoAd {
  id          String       @id @default(cuid())
  sellerId    String
  listingId   String?
  title       String
  subtitle    String?
  imageUrl    String
  ctaLabel    String       @default("Shop now")
  linkUrl     String?      // external or in-app path override
  package     PromoPackage @default(STANDARD)
  status      PromoStatus  @default(PENDING)
  sortOrder   Int          @default(0)
  startsAt    DateTime     @default(now())
  endsAt      DateTime
  pricePaid   Decimal      @db.Decimal(12, 2) @default(0)
  currency    String       @default("TZS")
  impressions Int          @default(0)
  clicks      Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  seller  SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  listing Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([status, endsAt, sortOrder])
  @@index([sellerId])
  @@map("promo_ads")
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

// ─── Orders & Escrow ─────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  addressId       String
  status          OrderStatus @default(PENDING_PAYMENT)
  subtotal        Decimal     @db.Decimal(12, 2)
  deliveryFee     Decimal     @db.Decimal(12, 2) @default(0)
  platformFee     Decimal     @db.Decimal(12, 2) @default(0)
  total           Decimal     @db.Decimal(12, 2)
  currency        String      @default("TZS")
  notes           String?
  preferredDriver Boolean     @default(false)
  confirmedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer  User      @relation("CustomerOrders", fields: [customerId], references: [id])
  address   Address   @relation(fields: [addressId], references: [id])
  items     OrderItem[]
  payment   Payment?
  escrow    Escrow?
  delivery  Delivery?
  dispute   Dispute?
  reviews   Review[]

  @@index([customerId, status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  listingId  String
  sellerId   String
  title      String
  unitPrice  Decimal @db.Decimal(12, 2)
  quantity   Int
  lineTotal  Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id])

  @@index([orderId])
  @@index([sellerId])
  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  provider        String        @default("clickpesa")
  providerRef     String?
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("TZS")
  status          PaymentStatus @default(PENDING)
  method          String?       // mobile_money | card | bank
  phone           String?
  metadata        Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([providerRef])
  @@map("payments")
}

model Escrow {
  id            String       @id @default(cuid())
  orderId       String       @unique
  amount        Decimal      @db.Decimal(12, 2)
  platformFee   Decimal      @db.Decimal(12, 2)
  sellerAmount  Decimal      @db.Decimal(12, 2)
  status        EscrowStatus @default(HELD)
  heldAt        DateTime     @default(now())
  releasedAt    DateTime?
  refundedAt    DateTime?
  notes         String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("escrows")
}

// ─── Delivery ────────────────────────────────────────────────────────────────

model Delivery {
  id              String         @id @default(cuid())
  orderId         String         @unique
  driverId        String?
  status          DeliveryStatus @default(REQUESTED)
  pickupLat       Float?
  pickupLng       Float?
  dropoffLat      Float?
  dropoffLng      Float?
  currentLat      Float?
  currentLng      Float?
  fee             Decimal        @db.Decimal(12, 2) @default(0)
  rejectReason    String?
  acceptedAt      DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order  Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver DriverProfile? @relation(fields: [driverId], references: [id])

  @@index([driverId, status])
  @@index([status])
  @@map("deliveries")
}

// ─── Reviews & Disputes ──────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  orderId    String
  authorId   String
  sellerId   String?
  driverId   String?
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  order  Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User           @relation("ReviewsGiven", fields: [authorId], references: [id])
  seller SellerProfile? @relation("SellerReviews", fields: [sellerId], references: [id])
  driver DriverProfile? @relation("DriverReviews", fields: [driverId], references: [id])

  @@unique([orderId, authorId, sellerId])
  @@unique([orderId, authorId, driverId])
  @@map("reviews")
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String        @unique
  openedById  String
  reason      String
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("disputes")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
